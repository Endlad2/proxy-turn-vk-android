<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Background glowing radial aura in brand blue -->
    <path
        android:pathData="M 54,14 A 40,40 0 1,1 53.999,14 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="40">
                <item android:color="#250474FB" android:offset="0.0" />
                <item android:color="#0A025ECB" android:offset="0.6" />
                <item android:color="#00000000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right Wing of the Stylized W (Behind) -->
    <path
        android:pathData="M 80,36 L 72,36 L 64,59 L 58,36 L 50,36 L 60,72 L 68,72 Z"
        android:fillType="nonZero">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="50"
                android:startY="36"
                android:endX="80"
                android:endY="72">
                <item android:color="#0056c2" android:offset="0.0" />
                <item android:color="#0360d4" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Left Wing of the Stylized W (In Front) -->
    <path
        android:pathData="M 28,36 L 36,36 L 44,59 L 50,36 L 58,36 L 48,72 L 40,72 Z"
        android:fillType="nonZero">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="28"
                android:startY="36"
                android:endX="58"
                android:endY="72">
                <item android:color="#4FA3FF" android:offset="0.0" />
                <item android:color="#0474fb" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
